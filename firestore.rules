rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -- Helpers ----------------------------------------------------------

    function isSignedIn() {
      return request.auth != null
        && request.auth.token.email_verified == true;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function isHouseholdMember(hid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/households/$(hid))
        && userEmail() in get(/databases/$(database)/documents/households/$(hid)).data.member_emails;
    }

    // -- Household-scoped data -------------------------------------------

    match /households/{hid} {
      // Members can read their household doc to display baby info.
      allow read: if isHouseholdMember(hid);
      // Household docs are seeded by the migration script (admin SDK).
      // Block client writes; future invite flow will be a Cloud Function.
      allow write: if false;

      match /events/{eventId} {
        allow read: if isHouseholdMember(hid);

        allow create: if isHouseholdMember(hid)
          && request.resource.data.created_by == request.auth.uid;

        allow update, delete: if isHouseholdMember(hid)
          && (request.time.toMillis() - resource.data.occurred_at.toMillis())
             < 24 * 60 * 60 * 1000;
      }

      match /config/{docId} {
        allow read, write: if isHouseholdMember(hid);
      }

      // Pre-aggregated daily rollups maintained by the dual-write path in
      // lib/useEvents.ts. Source of truth is the events subcollection; if
      // these get out of sync, scripts/backfill-summaries.ts can rebuild
      // them. Both fields and writes are trusted from any household member.
      match /daily_summaries/{dayKey} {
        allow read, write: if isHouseholdMember(hid);
      }

      // Materialized view docs (home / insights / library). One read per
      // screen. Maintained by the same dual-write path; rebuildable via
      // scripts/backfill-views.ts.
      match /views/{viewId} {
        allow read, write: if isHouseholdMember(hid);
      }
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
