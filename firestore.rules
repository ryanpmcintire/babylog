rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isHouseholdMember() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in [
          'ryanpmcintire@gmail.com',
          'kellynmelanson@gmail.com'
        ];
    }

    match /events/{eventId} {
      allow read: if isHouseholdMember();

      allow create: if isHouseholdMember()
        && request.resource.data.created_by == request.auth.uid;

      allow update, delete: if isHouseholdMember()
        && resource.data.created_by == request.auth.uid
        && (request.time.toMillis() - resource.data.occurred_at.toMillis()) < 24 * 60 * 60 * 1000;
    }

    match /config/{docId} {
      allow read, write: if isHouseholdMember();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
